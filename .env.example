# App Store Connect API credentials for scripts/asc_downloads.py
# Copy this file to .env (which is gitignored) and fill in real values.
# LOCAL USE ONLY — never commit real values. The .p8 file is the actual secret.

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_VENDOR_NUMBER=
# Path to your downloaded private key. Keep it out of git (*.p8 is gitignored).
# Optional: auto-detected if a single .p8 sits in the repo root.
#ASC_PRIVATE_KEY=./AuthKey_XXXXXX.p8
